---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const SITE_URL = "https://automatic-demo.com";

const {
  title = "Cloudflare Demos | Explore Cloudflare Solutions & Features",
  description = "Discover interactive Cloudflare solution demos showcasing security, performance, and developer tools.",
  ogImage = "/thumbnail.png",
  canonicalUrl = SITE_URL + Astro.url.pathname,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Cloudflare, security, performance, CDN, WAF, Zero Trust, networking, developer tools" />
    <meta name="author" content="DavidJKTofan" />
    <meta name="robots" content="max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE_URL}${ogImage}`} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE_URL}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Theme: apply immediately to prevent flash -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem("theme");
        document.documentElement.dataset.theme = saved || "dark";
      })();
    </script>

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <slot />

    <style is:global>
      /* ===== CSS Variables ===== */
      :root {
        --primary: #f6821f;
        --secondary: #0051c3;
        --bg: #f7f8fa;
        --card: #ffffff;
        --text: #212529;
        --border: #dee2e6;
        --hover: #f1f3f5;
        --focus: rgba(0, 81, 195, 0.25);
        --link: #0051c3;
        --link-hover: #f6821f;
        --code-bg: #f4f4f4;
        --shadow: rgba(0, 0, 0, 0.06);
      }

      :root[data-theme="dark"] {
        --primary: #f6821f;
        --secondary: #4693ff;
        --bg: #1a1a1a;
        --card: #2d2d2d;
        --text: #e0e0e0;
        --border: #404040;
        --hover: #363636;
        --focus: rgba(70, 147, 255, 0.3);
        --link: #66b3ff;
        --link-hover: #ff9f4d;
        --code-bg: #1a1a1a;
        --shadow: rgba(0, 0, 0, 0.25);
      }

      /* ===== Reset & Base ===== */
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
        -webkit-text-size-adjust: 100%;
      }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *, *::before, *::after { transition: none !important; animation: none !important; }
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Helvetica Neue", sans-serif;
        background-color: var(--bg);
        color: var(--text);
        line-height: 1.6;
        transition: background-color 0.25s ease, color 0.25s ease;
        min-height: 100dvh;
      }

      /* ===== Links ===== */
      a {
        color: var(--link);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: color 0.2s ease, border-color 0.2s ease;
      }
      a:hover {
        color: var(--link-hover);
        border-bottom-color: currentColor;
      }

      /* ===== Focus ===== */
      :focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 2px;
        box-shadow: 0 0 0 4px var(--focus);
      }

      /* ===== Layout ===== */
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1rem;
        width: 100%;
      }

      @media (min-width: 769px) {
        .container { padding: 1.5rem; }
      }

      @supports (padding: max(0px)) {
        .container {
          padding-left: max(1rem, env(safe-area-inset-left));
          padding-right: max(1rem, env(safe-area-inset-right));
        }
      }

      /* ===== Header ===== */
      header {
        background-color: var(--card);
        box-shadow: 0 2px 6px var(--shadow);
        padding: 0.75rem 1rem;
        position: sticky;
        top: 0;
        z-index: 100;
        transition: background-color 0.25s ease;
      }

      @media (max-width: 768px) {
        header { position: relative; }
      }

      /* ===== Footer ===== */
      footer {
        background-color: var(--card);
        border-top: 1px solid var(--border);
        text-align: center;
        padding: 1.5rem;
        margin-top: 3rem;
        color: #777;
        font-size: 0.85rem;
        transition: background-color 0.25s ease;
      }

      footer p + p {
        margin-top: 0.5rem;
        font-size: 0.78rem;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.5;
      }

      /* ===== Theme Toggle ===== */
      .theme-toggle {
        background: none;
        border: none;
        padding: 0.4rem;
        cursor: pointer;
        color: var(--text);
        border-radius: 50%;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background-color 0.2s;
        flex-shrink: 0;
      }
      .theme-toggle:hover { background-color: var(--hover); }

      .sun-icon, .moon-icon { fill: currentColor; }
      [data-theme="dark"] .sun-icon { display: none; }
      [data-theme="light"] .moon-icon { display: none; }
      :root:not([data-theme]) .moon-icon { display: none; }

      /* ===== Heading ===== */
      h1 { color: var(--secondary); line-height: 1.2; }

      /* ===== Code ===== */
      pre {
        background: var(--card);
        padding: 1rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow-x: auto;
        white-space: pre-wrap;
        box-shadow: 0 2px 8px var(--shadow);
        font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
      }

      code {
        display: block;
        color: var(--text);
        line-height: 1.5;
        font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        font-size: 0.9em;
        background-color: var(--code-bg);
        padding: 0.2rem 0.4rem;
        border-radius: 4px;
        white-space: pre-wrap;
        word-break: break-word;
      }

      /* ===== Image Dark Mode ===== */
      [data-theme="dark"] img {
        opacity: 0.9;
        transition: opacity 0.2s ease;
      }
      [data-theme="dark"] img:hover { opacity: 1; }

      /* ===== High Contrast ===== */
      @media (forced-colors: active) {
        .demo-card, button, input { border: 1px solid CanvasText; }
      }

      /* ===== Print ===== */
      @media print {
        .theme-toggle, .home-button { display: none; }
        body { background: white !important; color: black !important; }
        a[href]::after { content: " (" attr(href) ")"; }
      }
    </style>
  </body>
</html>
