    .btn-row { flex-direction: column; }
    .btn { min-width: unset; }
  }
</style>

<script>
  const form = document.getElementById('transformForm') as HTMLFormElement | null;
  const transformUrl = document.getElementById('transformUrl');
  const transformedImage = document.getElementById('transformedImage') as HTMLImageElement | null;
  const baseImagePath = '/demos/performance/img/munich-original-img.jpeg';

  function updateImage() {
    if (!form || !transformUrl || !transformedImage) return;
    const formData = new FormData(form);
    const params: string[] = [];

    for (const [key, value] of formData.entries()) {
      if (value) params.push(`${key}=${value}`);
    }

    const transformString = params.join(',');
    const fullUrl = `/cdn-cgi/image/${transformString}${baseImagePath}`;
    transformUrl.textContent = fullUrl;
    transformedImage.src = fullUrl;
  }

  form?.querySelectorAll('input, select').forEach((input) => {
    input.addEventListener('change', updateImage);
    input.addEventListener('input', updateImage);
  });

  updateImage();
</script>
