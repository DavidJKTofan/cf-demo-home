---
import DemoLayout from '../../../layouts/DemoLayout.astro';
---

<DemoLayout
  title="WAF Demo"
  description="The Cloudflare WAF is a Web Application Firewall that protects your HTTP/S web applications from common and new vulnerabilities."
  category="Application Security"
  labels={["WAF", "Firewall", "Security"]}
  lastUpdated="March 2025"
>

  <!-- Overview Card -->
  <section class="card" aria-labelledby="overview-heading">
    <h2 id="overview-heading">Overview</h2>
    <p>
      The Cloudflare WAF is a Web Application Firewall that protects your{' '}
      <a href="https://developers.cloudflare.com/fundamentals/reference/network-ports/" target="_blank" rel="noopener noreferrer external">
        HTTP/S
      </a>{' '}
      web applications from common and new vulnerabilities. It mainly consists of the following components:
    </p>
    <ul class="feature-list">
      <li>
        <a href="https://developers.cloudflare.com/waf/detections/" target="_blank" rel="noopener noreferrer external">
          <strong>Traffic Detections</strong>
        </a>
      </li>
      <li>
        <a href="https://developers.cloudflare.com/waf/custom-rules/" target="_blank" rel="noopener noreferrer external">
          <strong>Custom Rules</strong>
        </a>
      </li>
      <li>
        <a href="https://developers.cloudflare.com/waf/rate-limiting-rules/" target="_blank" rel="noopener noreferrer external">
          <strong>Rate Limiting Rules</strong>
        </a>
      </li>
      <li>
        <a href="https://developers.cloudflare.com/waf/managed-rules/" target="_blank" rel="noopener noreferrer external">
          <strong>WAF Managed Rules</strong>
        </a>
      </li>
      <li>
        <a href="https://developers.cloudflare.com/waf/tools/" target="_blank" rel="noopener noreferrer external">
          <strong>Additional Tools</strong>
        </a>
      </li>
    </ul>
    <p class="mt-1">
      Take advantage of a multitude of{' '}
      <a href="https://developers.cloudflare.com/ruleset-engine/rules-language/fields/reference/" target="_blank" rel="noopener noreferrer external">fields</a>
      {' '}and even{' '}
      <a href="https://developers.cloudflare.com/ruleset-engine/rules-language/functions/" target="_blank" rel="noopener noreferrer external">functions</a>
      {' '}to create rules.
    </p>
    <p class="mt-1">
      For practical security recommendations and security rules examples, check out{' '}
      <a href="https://davidtofan.com/articles/cloudflare-l7-security-recommendations/" target="_blank" rel="noopener noreferrer">
        General Application Security Recommendations
      </a>.
    </p>
    <div class="btn-row">
      <a
        href="https://appsec.automatic-demo.com/"
        target="_blank"
        rel="noopener noreferrer external"
        class="btn btn-primary"
      >
        AppSec Demo Page (behind ZTNA)
      </a>
      <a
        href="https://www.cf-testing.com/?url=file:///etc/passwd"
        target="_blank"
        rel="noopener noreferrer external"
        class="btn btn-secondary"
      >
        Demo: WAF Managed Rule
      </a>
      <a
        href="https://hmac.automatic-demo.com/"
        target="_blank"
        rel="noopener noreferrer external"
        class="btn btn-secondary"
      >
        Demo: HMAC Authentication with WAF Custom Rule
      </a>
    </div>
  </section>

  <!-- Security Analytics -->
  <section aria-labelledby="analytics-heading">
    <h2 id="analytics-heading">Security Analytics</h2>
    <div class="img-container">
      <img
        src="/demos/security/img/cf-zone-waf-analytics.png"
        alt="Zone WAF Security Analytics Dashboard in Cloudflare"
        loading="lazy"
      />
    </div>
  </section>

  <!-- Security Rules Gallery -->
  <section aria-labelledby="rules-heading">
    <h2 id="rules-heading">Security Rules</h2>
    <div class="responsive-grid">
      <div class="card small">
        <h3>Cloudflare-branded Managed Challenge</h3>
        <div class="img-container">
          <img
            src="/demos/security/img/cf-waf-managed-challenge.png"
            alt="Demo: Cloudflare-branded Managed Challenge page"
            loading="lazy"
          />
        </div>
      </div>
      <div class="card small">
        <h3>Cloudflare-branded Block</h3>
        <div class="img-container">
          <img
            src="/demos/security/img/cf-waf-block.png"
            alt="Demo: Cloudflare-branded Block page"
            loading="lazy"
          />
        </div>
      </div>
      <div class="card small">
        <h3>Custom-branded Managed Challenge</h3>
        <p>
          Use{' '}
          <a href="https://developers.cloudflare.com/support/more-dashboard-apps/cloudflare-custom-pages/configuring-custom-pages-error-and-challenge/" target="_blank" rel="noopener noreferrer external">
            Custom Pages
          </a>{' '}
          to create a custom-branded Managed Challenge. For advanced customization on errors, use the{' '}
          <a href="https://developers.cloudflare.com/rules/custom-errors/" target="_blank" rel="noopener noreferrer external">
            Custom Errors
          </a>{' '}
          feature.
        </p>
        <div class="img-container mt-1">
          <img
            src="/demos/security/img/custom-pages-managed-challenge-template.png"
            alt="Demo: Custom-branded Managed Challenge page"
            loading="lazy"
          />
        </div>
      </div>
      <div class="card small">
        <h3>Block with Custom JSON Response</h3>
        <p>
          Use{' '}
          <a href="https://developers.cloudflare.com/waf/custom-rules/create-dashboard/#configure-a-custom-response-for-blocked-requests" target="_blank" rel="noopener noreferrer external">
            Custom Response
          </a>{' '}
          to trigger an action on your native mobile application or for a service to use.
        </p>
        <div class="img-container mt-1">
          <img
            src="/demos/security/img/cf-waf-block-custom-json-response.png"
            alt="Demo: Block with Custom JSON Response"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Leaked Credentials Detection Demo -->
  <section class="card" aria-labelledby="leaked-creds-heading">
    <h2 id="leaked-creds-heading">Leaked Credentials Detection Demo</h2>
    <p>
      This demo shows how Cloudflare's WAF can detect and prevent the use of leaked credentials in login attempts.
    </p>
    <form id="loginForm" class="login-form" novalidate>
      <div class="form-group">
        <label for="username">Username</label>
        <input
          type="text"
          id="username"
          name="username"
          value="CF_EXPOSED_USERNAME"
          autocomplete="off"
        />
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          value="CF_EXPOSED_PASSWORD"
        />
      </div>
      <button type="submit" class="btn btn-secondary">Sign In</button>
    </form>
    <div id="loginResponse" class="login-response" aria-live="polite" aria-atomic="true"></div>

    <h3 class="mt-2">API Example</h3>
    <p>Test the leaked credentials detection using curl:</p>
    <div class="code-block">
      <button class="copy-btn" id="copyCmd" aria-label="Copy curl command" type="button">
        Copy
      </button>
      <pre><code id="curlCmd">curl -s 'https://turnstile.automatic-demo.com/handler' \
  -X POST \
  -H "Content-Type: application/x-www-form-urlencoded" \
  -d 'username=CF_EXPOSED_USERNAME@example.com&password=CF_EXPOSED_PASSWORD' \
  -i</code></pre>
    </div>
  </section>

  <!-- Security Recommendations Database -->
  <section class="card" aria-labelledby="db-heading">
    <h2 id="db-heading">Security Recommendations Database</h2>
    <p>
      Explore a curated database of security recommendations, rule templates, and best practices
      that you can adapt for your own security needs.
    </p>
    <div class="btn-row mt-1">
      <a
        href="https://db.automatic-demo.com/"
        target="_blank"
        rel="noopener noreferrer external"
        class="btn btn-secondary"
      >
        Browse Security Rules Database
      </a>
    </div>
  </section>

</DemoLayout>

<style>
  /* ===== Section spacing ===== */
  section {
    margin-bottom: 2.5rem;
  }

  section > h2 {
    font-size: clamp(1.15rem, 3vw, 1.45rem);
    color: var(--secondary);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
  }

  /* ===== Card ===== */
  .card {
    background-color: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .card h2 {
    border-bottom-color: var(--border);
  }

  .card.small {
    margin-bottom: 0;
  }

  .card.small h3 {
    font-size: 1rem;
    color: var(--secondary);
    margin-bottom: 0.75rem;
  }

  .card p, section > p {
    margin-bottom: 0.75rem;
    line-height: 1.7;
  }

  /* ===== Feature list ===== */
  .feature-list {
    list-style: disc;
    padding-left: 1.5rem;
    margin: 0.75rem 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  /* ===== Utility ===== */
  .mt-1 { margin-top: 1rem; }
  .mt-2 { margin-top: 1.5rem; }

  /* ===== Button Row ===== */
  .btn-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .btn {
    display: inline-block;
    padding: 0.6rem 1.2rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    border-bottom: none !important;
  }

  .btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
    border-bottom: none !important;
  }

  .btn-primary {
    background-color: var(--primary);
    color: white;
  }

  .btn-secondary {
    background-color: var(--secondary);
    color: white;
  }

  /* ===== Image Container ===== */
  .img-container {
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid var(--secondary);
  }

  .img-container img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ===== Responsive Grid ===== */
  .responsive-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 600px) {
    .responsive-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ===== Login Form ===== */
  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1rem 0;
    max-width: 480px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-group label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
  }

  .form-group input {
    padding: 0.55rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.95rem;
    background-color: var(--bg);
    color: var(--text);
    transition: border-color 0.2s, box-shadow 0.2s;
    width: 100%;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--secondary);
    box-shadow: 0 0 0 3px var(--focus);
  }

  .login-response {
    margin-top: 0.75rem;
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 0.9rem;
    min-height: 1.5rem;
    padding: 0.5rem 0;
    color: var(--text);
    white-space: pre-wrap;
  }

  /* ===== Code Block ===== */
  .code-block {
    position: relative;
    margin-top: 0.75rem;
  }

  .code-block pre {
    padding-top: 2.5rem;
  }

  .copy-btn {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    padding: 0.3rem 0.7rem;
    background: var(--hover);
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.8rem;
    color: var(--text);
    z-index: 1;
    transition: background-color 0.2s;
  }

  .copy-btn:hover { background-color: var(--border); }

  /* ===== Mobile ===== */
  @media (max-width: 600px) {
    .btn-row { flex-direction: column; }
    .btn { text-align: center; }
  }
</style>

<script>
  // Login form demo
  const loginForm = document.getElementById('loginForm') as HTMLFormElement | null;
  const loginResponse = document.getElementById('loginResponse');

  loginForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const username = (document.getElementById('username') as HTMLInputElement).value + '@example.com';
    const password = (document.getElementById('password') as HTMLInputElement).value;

    if (loginResponse) loginResponse.textContent = 'Sending request...';

    try {
      await fetch('https://turnstile.automatic-demo.com/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `username=${encodeURIComponent(username)}&password=${encodeURIComponent(password)}`,
      });
      if (loginResponse) loginResponse.textContent = 'No leaked credentials found.';
    } catch {
      if (loginResponse) loginResponse.textContent = 'Blocked: Leaked credentials detected!';
    }
  });

  // Copy button
  const copyBtn = document.getElementById('copyCmd');
  const curlCmd = document.getElementById('curlCmd');
  copyBtn?.addEventListener('click', async () => {
    if (!curlCmd) return;
    try {
      await navigator.clipboard.writeText(curlCmd.textContent || '');
      copyBtn.textContent = 'Copied!';
      setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000);
    } catch {
      copyBtn.textContent = 'Failed';
    }
  });
</script>
