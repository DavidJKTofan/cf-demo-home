---
import Layout from '../layouts/Layout.astro';
import DemoCard from '../components/DemoCard.astro';
import demosData from '../../public/demos.json';

interface Demo {
  id: number;
  title: string;
  description: string;
  url: string;
  category: string;
  labels: string[];
}

const demos: Demo[] = demosData;

// Derive unique categories and labels for filters
const categories = [...new Set(demos.map((d) => d.category))].sort();
const allLabels = [...new Set(demos.flatMap((d) => d.labels))].sort();
---

<Layout
  title="Cloudflare Demos | Explore Cloudflare Solutions & Features"
  description="Discover interactive Cloudflare solution demos showcasing security, performance, and developer tools."
>
  <header>
    <div class="container">
      <div class="header-content">
        <h1>Cloudflare Demos</h1>
        <div class="filters" role="search" aria-label="Filter demos">
          <div class="search-box">
            <input
              type="text"
              id="searchInput"
              placeholder="Search demos..."
              aria-label="Search demos"
              autocomplete="off"
            />
          </div>

          <div class="filter-dropdown" id="categoryDropdown">
            <button
              class="dropdown-btn"
              id="categoryFilterBtn"
              aria-haspopup="listbox"
              aria-expanded="false"
              type="button"
            >
              <span id="categoryLabel">Filter by Category</span>
              <svg class="chevron" viewBox="0 0 16 16" width="12" height="12" fill="currentColor" aria-hidden="true">
                <path d="M1.5 5.5l6.5 6 6.5-6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="dropdown-content" id="categoryFilterContent" role="listbox" aria-label="Categories">
              {categories.map((cat) => (
                <label class="checkbox-item">
                  <input type="checkbox" name="category" value={cat} />
                  <span>{cat}</span>
                </label>
              ))}
            </div>
          </div>

          <div class="filter-dropdown" id="labelDropdown">
            <button
              class="dropdown-btn"
              id="labelFilterBtn"
              aria-haspopup="listbox"
              aria-expanded="false"
              type="button"
            >
              <span id="labelLabel">Filter by Product</span>
              <svg class="chevron" viewBox="0 0 16 16" width="12" height="12" fill="currentColor" aria-hidden="true">
                <path d="M1.5 5.5l6.5 6 6.5-6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="dropdown-content" id="labelFilterContent" role="listbox" aria-label="Products">
              {allLabels.map((label) => (
                <label class="checkbox-item">
                  <input type="checkbox" name="label" value={label} />
                  <span>{label}</span>
                </label>
              ))}
            </div>
          </div>

          <button class="clear-filters" id="clearFilters" type="button">
            Clear Filters
          </button>
        </div>

        <button
          class="theme-toggle"
          id="themeToggle"
          aria-label="Toggle light/dark theme"
          title="Toggle light/dark theme"
          type="button"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg class="sun-icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
            <path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41l-1.06-1.06zm1.06-10.96c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 18.36c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z" fill="currentColor"/>
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg class="moon-icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
            <path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36-.98 1.37-2.58 2.26-4.4 2.26-3.03 0-5.5-2.47-5.5-5.5 0-1.82.89-3.42 2.26-4.4-.44-.06-.9-.1-1.36-.1z" fill="currentColor"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <main class="container" id="main-content">
    <div class="results-info" id="resultsInfo" aria-live="polite" aria-atomic="true"></div>
    <div class="demo-grid" id="demoGrid" role="main">
      {demos.map((demo) => (
        <DemoCard
          id={demo.id}
          title={demo.title}
          description={demo.description}
          url={demo.url}
          category={demo.category}
          labels={demo.labels}
        />
      ))}
    </div>
    <div class="no-results" id="noResults" hidden aria-live="polite">
      No demos found matching your filters.
    </div>
  </main>

  <footer>
    <div class="container">
      <p>&copy; {new Date().getFullYear()} automatic-demo.com</p>
      <p class="disclaimer">
        This is an unofficial demonstration website. Not affiliated with or endorsed by Cloudflare.
        All product names, logos, and brands are property of Cloudflare. This site is for informational
        purposes only and comes with no warranty or guarantee of accuracy.
      </p>
    </div>
  </footer>

  <noscript>
    <style>#demoGrid .demo-card { display: flex !important; }</style>
  </noscript>
</Layout>

<style>
  /* ===== Header Content ===== */
  .header-content {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  h1 {
    font-size: clamp(1.2rem, 4vw, 1.7rem);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ===== Filters ===== */
  .filters {
    display: flex;
    flex: 1;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  /* ===== Search ===== */
  .search-box {
    flex: 1;
    min-width: 160px;
  }

  .search-box input {
    width: 100%;
    padding: 0.55rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.95rem;
    background-color: var(--card);
    color: var(--text);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .search-box input:focus {
    outline: none;
    border-color: var(--secondary);
    box-shadow: 0 0 0 3px var(--focus);
  }

  /* ===== Dropdowns ===== */
  .filter-dropdown {
    position: relative;
    min-width: 175px;
    flex: 1;
  }

  .dropdown-btn {
    width: 100%;
    padding: 0.55rem 0.9rem;
    background-color: var(--card);
    border: 1px solid var(--border);
    border-radius: 6px;
    text-align: left;
    cursor: pointer;
    font-size: 0.95rem;
    color: var(--text);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    transition: border-color 0.2s, background-color 0.2s;
  }

  .dropdown-btn:hover { background-color: var(--hover); }
  .dropdown-btn[aria-expanded="true"] {
    border-color: var(--primary);
    background-color: var(--hover);
  }
  .dropdown-btn.has-filters {
    border-color: var(--primary);
    color: var(--primary);
    font-weight: 500;
  }

  .chevron {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }
  .dropdown-btn[aria-expanded="true"] .chevron {
    transform: rotate(180deg);
  }

  .dropdown-content {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    min-width: 100%;
    background-color: var(--card);
    border: 1px solid var(--border);
    border-radius: 6px;
    z-index: 200;
    box-shadow: 0 6px 20px var(--shadow);
    max-height: 280px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--primary) transparent;
  }

  .dropdown-content.show { display: block; }

  .checkbox-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 0.9rem;
    cursor: pointer;
    transition: background-color 0.15s;
    user-select: none;
    font-size: 0.9rem;
  }

  .checkbox-item:not(:last-child) {
    border-bottom: 1px solid var(--border);
  }

  .checkbox-item:hover { background-color: var(--hover); }

  .checkbox-item input[type="checkbox"] {
    width: 15px;
    height: 15px;
    accent-color: var(--primary);
    flex-shrink: 0;
    cursor: pointer;
  }

  /* ===== Clear Filters ===== */
  .clear-filters {
    padding: 0.55rem 0.9rem;
    background-color: var(--card);
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.95rem;
    color: var(--text);
    white-space: nowrap;
    transition: background-color 0.2s, border-color 0.2s;
    flex-shrink: 0;
  }

  .clear-filters:hover {
    background-color: var(--hover);
    border-color: var(--primary);
  }

  /* ===== Results Info ===== */
  .results-info {
    font-size: 0.85rem;
    color: #888;
    padding: 0.75rem 0 0.25rem;
    min-height: 1.5rem;
  }

  /* ===== Demo Grid ===== */
  .demo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
    gap: 1.25rem;
    padding: 0.5rem 0 2rem;
  }

  @media (max-width: 480px) {
    .demo-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  @media (min-width: 481px) and (max-width: 768px) {
    .demo-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ===== No Results ===== */
  .no-results {
    text-align: center;
    padding: 3rem 1rem;
    color: #888;
    font-size: 1rem;
  }

  /* ===== Mobile layout ===== */
  @media (max-width: 768px) {
    .header-content {
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      position: relative;
    }

    h1 {
      padding-right: 48px; /* space for theme toggle */
    }

    .filters {
      flex-direction: column;
      width: 100%;
    }

    .search-box,
    .filter-dropdown,
    .clear-filters {
      width: 100%;
      min-width: unset;
      flex: none;
    }

    .theme-toggle {
      position: absolute;
      top: 0;
      right: 0;
    }

    .search-box input,
    .dropdown-btn {
      font-size: 16px; /* prevent iOS zoom */
    }
  }

  /* ===== Touch target improvements ===== */
  @media (hover: none) and (pointer: coarse) {
    .search-box input,
    .dropdown-btn,
    .clear-filters,
    .checkbox-item {
      padding: 0.8rem 0.9rem;
      min-height: 44px;
    }
  }
</style>

<script>
  // ===== Theme Toggle =====
  const themeToggle = document.getElementById('themeToggle');
  themeToggle?.addEventListener('click', () => {
    const current = document.documentElement.dataset.theme || 'dark';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('theme', next);
  });

  // ===== Dropdown Management =====
  function setupDropdown(btnId: string, contentId: string) {
    const btn = document.getElementById(btnId) as HTMLButtonElement | null;
    const content = document.getElementById(contentId);
    if (!btn || !content) return;

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = content.classList.contains('show');
      // Close all dropdowns first
      document.querySelectorAll('.dropdown-content.show').forEach((el) => {
        el.classList.remove('show');
      });
      document.querySelectorAll('.dropdown-btn[aria-expanded="true"]').forEach((el) => {
        el.setAttribute('aria-expanded', 'false');
      });
      // Toggle this one
      if (!isOpen) {
        content.classList.add('show');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  }

  setupDropdown('categoryFilterBtn', 'categoryFilterContent');
  setupDropdown('labelFilterBtn', 'labelFilterContent');

  // Close dropdowns when clicking outside
  document.addEventListener('click', () => {
    document.querySelectorAll('.dropdown-content.show').forEach((el) => {
      el.classList.remove('show');
    });
    document.querySelectorAll('.dropdown-btn[aria-expanded="true"]').forEach((el) => {
      el.setAttribute('aria-expanded', 'false');
    });
  });

  // ===== Filtering Logic =====
  function getCheckedValues(name: string): string[] {
    return Array.from(
      document.querySelectorAll<HTMLInputElement>(`input[name="${name}"]:checked`)
    ).map((el) => el.value);
  }

  function updateFilterBtnState(btnId: string, hasFilters: boolean) {
    const btn = document.getElementById(btnId);
    if (hasFilters) {
      btn?.classList.add('has-filters');
    } else {
      btn?.classList.remove('has-filters');
    }
  }

  function filterDemos() {
    const query = (document.getElementById('searchInput') as HTMLInputElement)?.value.toLowerCase().trim() || '';
    const selectedCategories = getCheckedValues('category');
    const selectedLabels = getCheckedValues('label');

    updateFilterBtnState('categoryFilterBtn', selectedCategories.length > 0);
    updateFilterBtnState('labelFilterBtn', selectedLabels.length > 0);

    const cards = document.querySelectorAll<HTMLElement>('.demo-card');
    let visibleCount = 0;

    cards.forEach((card) => {
      const title = card.querySelector('.demo-title')?.textContent?.toLowerCase() || '';
      const description = card.querySelector('.demo-description')?.textContent?.toLowerCase() || '';
      const category = card.dataset.category || '';
      const labels = (card.dataset.labels || '').split(',');

      const matchesSearch = !query || title.includes(query) || description.includes(query) || category.toLowerCase().includes(query);
      const matchesCategory = selectedCategories.length === 0 || selectedCategories.includes(category);
      const matchesLabel = selectedLabels.length === 0 || selectedLabels.some((l) => labels.includes(l));

      const visible = matchesSearch && matchesCategory && matchesLabel;
      card.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    // Update results info
    const resultsInfo = document.getElementById('resultsInfo');
    const noResults = document.getElementById('noResults');
    const totalCount = cards.length;

    if (resultsInfo) {
      const hasFilter = query || selectedCategories.length > 0 || selectedLabels.length > 0;
      resultsInfo.textContent = hasFilter
        ? `Showing ${visibleCount} of ${totalCount} demos`
        : '';
    }

    if (noResults) {
      noResults.hidden = visibleCount > 0;
    }
  }

  // Attach filter events
  document.getElementById('searchInput')?.addEventListener('input', filterDemos);
  document.querySelectorAll('input[name="category"], input[name="label"]').forEach((el) => {
    el.addEventListener('change', filterDemos);
  });

  // Clear filters
  document.getElementById('clearFilters')?.addEventListener('click', () => {
    (document.getElementById('searchInput') as HTMLInputElement).value = '';
    document.querySelectorAll<HTMLInputElement>('input[name="category"], input[name="label"]').forEach((el) => {
      el.checked = false;
    });
    filterDemos();
  });
</script>
