{
  "name": "cf-demo-home",
  "main": "src/index.js",
  "compatibility_date": "2025-04-09",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./public",
    "not_found_handling": "404-page"
  },
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "automatic-demo.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
